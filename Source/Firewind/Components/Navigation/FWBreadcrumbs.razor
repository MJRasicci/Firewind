@namespace Firewind.Components
@inherits FirewindComponentBase

<div @attributes="ComponentAttributes">
    <ul>
        @ChildContent
    </ul>
</div>

@code
{
    /// <summary>
    /// Gets or sets breadcrumb item markup.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets CSS classes for the breadcrumbs wrapper.
    /// </summary>
    protected override string CssClass => "fw-breadcrumbs";
}
