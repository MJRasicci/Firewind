@namespace Firewind.Components
@inherits FirewindComponentBase

<li @attributes="ComponentAttributes">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        if (Icon is not null)
        {
            <span class="@IconVisibility.IconClassNames()">@Icon</span>
        }

        if (LabelContent is not null)
        {
            <span class="@LabelVisibility.LabelClassNames()">@LabelContent</span>
        }
        else if (!string.IsNullOrWhiteSpace(Label))
        {
            <span class="@LabelVisibility.LabelClassNames()">@Label</span>
        }
    }
</li>

@code
{
    /// <summary>
    /// Gets or sets the menu section title text rendered when <see cref="LabelContent"/> is not supplied.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>
    /// Gets or sets custom title label content.
    /// </summary>
    [Parameter]
    public RenderFragment? LabelContent { get; set; }

    /// <summary>
    /// Gets or sets optional icon content displayed before the title label.
    /// </summary>
    [Parameter]
    public RenderFragment? Icon { get; set; }

    /// <summary>
    /// Gets or sets responsive visibility behavior for the title icon.
    /// </summary>
    [Parameter]
    public MenuContentVisibility IconVisibility { get; set; }

    /// <summary>
    /// Gets or sets responsive visibility behavior for the title label.
    /// </summary>
    [Parameter]
    public MenuContentVisibility LabelVisibility { get; set; }

    /// <summary>
    /// Gets or sets custom title content. When supplied, this replaces icon/label rendering.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets the root CSS class for the menu title item.
    /// </summary>
    protected override string CssClass => "fw-menu-title pointer-events-none";
}
