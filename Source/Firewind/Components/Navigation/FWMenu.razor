@namespace Firewind.Components
@typeparam TMenuItem
@inherits FirewindComponentBase

<ul @attributes="ComponentAttributes">
    @ChildContent

    @if (UseTreeRendering)
    {
        @foreach (var node in TreeRootNodes)
        {
            @RenderTreeNode(node)
        }
    }
    else
    {
        @foreach (var item in Items)
        {
            <li>@RenderFlatItem(item)</li>
        }
    }
</ul>

@code
{
    /// <summary>
    /// Renders a flat data item using the configured template pipeline.
    /// </summary>
    /// <param name="item">The item to render.</param>
    /// <returns>A render fragment representing the item.</returns>
    private RenderFragment RenderFlatItem(TMenuItem item) => (this.ItemTemplate ?? this.DefaultItemTemplate)(item);

    /// <summary>
    /// Gets the fallback template for flat data item rendering.
    /// </summary>
    private RenderFragment<TMenuItem> DefaultItemTemplate => (context) => (__builder) =>
    {
        <FWLink href="#">@context?.ToString()</FWLink>
    };

    /// <summary>
    /// Renders a tree node and its descendants.
    /// </summary>
    /// <param name="node">The node to render.</param>
    /// <returns>A render fragment representing the node.</returns>
    private RenderFragment RenderTreeNode(IDataTreeNode<TMenuItem> node) => __builder =>
    {
        var template = this.ResolveNodeTemplate(node);
        var hasChildren = node.Children.Count > 0;

        if (this.ShouldRenderNodeAsTitle(node))
        {
            <FWMenuTitle @key="@node.Key">
                <ChildContent>
                    @if (template is not null)
                    {
                        @template(node)
                    }
                    else
                    {
                        @this.ResolveNodeLabel(node)
                    }
                </ChildContent>
            </FWMenuTitle>

            foreach (var child in node.Children)
            {
                @RenderTreeNode(child)
            }

            return;
        }

        <FWMenuItem
            @key="@node.Key"
            As="@this.ResolveNodeActionElement(node)"
            Href="@this.ResolveNodeHref(node)"
            Behavior="@this.ResolveNodeBehavior(node)"
            Collapsible="@(hasChildren && node.IsCollapsible)"
            Open="@(hasChildren && node.IsExpanded)">
            <ItemContent>
                @if (template is not null)
                {
                    @template(node)
                }
                else
                {
                    @this.ResolveNodeLabel(node)
                }
            </ItemContent>
            <ChildContent>
                @if (hasChildren)
                {
                    @foreach (var child in node.Children)
                    {
                        @RenderTreeNode(child)
                    }
                }
            </ChildContent>
        </FWMenuItem>
    };
}
