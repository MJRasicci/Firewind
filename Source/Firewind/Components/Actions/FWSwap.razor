@namespace Firewind.Components
@inherits FirewindComponentBase

<label @attributes="ComponentAttributes">
    <div class="fw-swap-on">
        @On
    </div>

    <div class="fw-swap-off">
        @Off
    </div>
</label>

@code {
    /// <summary>
    /// Gets or sets content shown for the active state.
    /// </summary>
    [Parameter]
    public RenderFragment? On { get; set; }

    /// <summary>
    /// Gets or sets content shown for the inactive state.
    /// </summary>
    [Parameter]
    public RenderFragment? Off { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the swap is active.
    /// </summary>
    [Parameter]
    public bool State { get; set; }

    /// <summary>
    /// Gets or sets the animation style variant.
    /// </summary>
    [Parameter]
    public SwapStyle Style { get; set; }

    /// <summary>
    /// Gets the composed CSS class string for the swap component.
    /// </summary>
    protected override string CssClass => new VariantClassBuilder("fw-swap")
        .AddVariant(this.Style, static style => style.ClassNames())
        .AddIf(this.State, "fw-swap-active")
        .Build();
}
