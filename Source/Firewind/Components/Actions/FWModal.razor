@namespace Firewind.Components
@inherits FirewindComponentBase

<dialog @attributes="ComponentAttributes" @onclose="OnClosedAsync">
    <div class="fw-modal-box">
        @ChildContent
    </div>
    @if (this.ShouldRenderBackdropClose)
    {
        <form method="dialog" class="fw-modal-backdrop">
            <button type="submit">Close</button>
        </form>
    }
</dialog>

@code
{
    /// <summary>
    /// Gets or sets a value indicating whether the modal is open.
    /// </summary>
    [Parameter]
    public bool Open { get; set; }

    /// <summary>
    /// Gets or sets the callback raised when <see cref="Open"/> changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>
    /// Gets or sets content rendered inside the modal body.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the placement variant for the modal surface.
    /// </summary>
    [Parameter]
    public ModalPlacement Placement { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether clicking outside the modal surface closes the dialog.
    /// </summary>
    [Parameter]
    public bool CloseOnOutsideClick { get; set; } = true;

    /// <summary>
    /// Gets a value indicating whether the backdrop close form should be rendered.
    /// </summary>
    protected bool ShouldRenderBackdropClose => this.CloseOnOutsideClick;

    /// <summary>
    /// Gets the root CSS class for the modal component.
    /// </summary>
    protected override string CssClass => new VariantClassBuilder("fw-modal")
        .AddVariant(this.Placement, static placement => placement.ClassNames())
        .AddIf(this.Open, "fw-modal-open")
        .Build();

    /// <summary>
    /// Handles the dialog close event and notifies binders that the modal closed.
    /// </summary>
    /// <returns>A task that represents the asynchronous callback invocation.</returns>
    private async Task OnClosedAsync()
    {
        this.Open = false;
        await OpenChanged.InvokeAsync(this.Open);
    }
}
