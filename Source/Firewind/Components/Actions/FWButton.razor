@namespace Firewind.Components
@inherits FirewindComponentBase

<DynamicElement Tag="@As" OnClick="HandleClickAsync" PreventDefaultOnClick="@Disabled" @attributes="ComponentAttributes">
    @ChildContent
</DynamicElement>

@code
{
    /// <summary>
    /// Gets or sets a value indicating whether the button is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the active modifier class is applied.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }

    /// <summary>
    /// Gets or sets the button size variant.
    /// </summary>
    [Parameter]
    public ComponentSize Size { get; set; }

    /// <summary>
    /// Gets or sets the visual style variant.
    /// </summary>
    [Parameter]
    public ButtonStyle Style { get; set; }

    /// <summary>
    /// Gets or sets the button shape variant.
    /// </summary>
    [Parameter]
    public ButtonShape Shape { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the outline style should be applied.
    /// </summary>
    [Parameter]
    public bool Outline { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the dashed variant should be applied.
    /// </summary>
    [Parameter]
    public bool Dash { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the soft variant should be applied.
    /// </summary>
    [Parameter]
    public bool Soft { get; set; }

    /// <summary>
    /// The element to be used for rendering the button. Defaults to 'button'.
    /// </summary>
    [Parameter]
    public string As { get; set; } = "button";

    /// <summary>
    /// The content to be rendered inside the button.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the button is clicked.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    /// <summary>
    /// Ensures default element attributes are applied after parameters are set.
    /// </summary>
    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        var isButtonElement = string.Equals(this.As, "button", StringComparison.OrdinalIgnoreCase);

        if (isButtonElement)
        {
            if (!this.MutableComponentAttributes.ContainsKey("type"))
            {
                this.MutableComponentAttributes["type"] = "button";
            }

            if (this.Disabled)
            {
                this.MutableComponentAttributes["disabled"] = true;
            }
            else
            {
                this.MutableComponentAttributes.Remove("disabled");
            }

            this.MutableComponentAttributes.Remove("aria-disabled");
            return;
        }

        this.MutableComponentAttributes.Remove("disabled");

        if (this.Disabled)
        {
            this.MutableComponentAttributes["aria-disabled"] = "true";
            if (!this.MutableComponentAttributes.ContainsKey("tabindex"))
            {
                this.MutableComponentAttributes["tabindex"] = "-1";
            }
        }
        else
        {
            this.MutableComponentAttributes.Remove("aria-disabled");

            if (this.AdditionalAttributes is null || !this.AdditionalAttributes.ContainsKey("tabindex"))
            {
                this.MutableComponentAttributes.Remove("tabindex");
            }
        }
    }

    /// <summary>
    /// Dispatches click events only when the component is enabled.
    /// </summary>
    /// <param name="args">The click event arguments.</param>
    /// <returns>A task that represents the asynchronous callback invocation.</returns>
    private async Task HandleClickAsync(MouseEventArgs args)
    {
        if (this.Disabled)
        {
            return;
        }

        await this.OnClick.InvokeAsync(args);
    }
    
    /// <summary>
    /// Gets the composed CSS class string for the button instance.
    /// </summary>
    protected override string CssClass => new VariantClassBuilder("fw-btn")
        .AddVariant(this.Shape, static shape => shape.ClassNames())
        .AddIf(this.Outline, "fw-btn-outline")
        .AddIf(this.Dash, "fw-btn-dash")
        .AddIf(this.Soft, "fw-btn-soft")
        .AddVariant(this.Style, static style => style.ClassNames())
        .AddVariant(this.Size, static size => size.ButtonClassNames())
        .AddIf(this.Active, "fw-btn-active")
        .Build();
}
