@namespace Firewind.Components
@inherits FirewindComponentBase

<DynamicElement Tag="@As" @onclick="OnClick" @attributes="ComponentAttributes" disabled="@Disabled">
    @ChildContent
</DynamicElement>

@code
{
    /// <summary>
    /// Gets or sets a value indicating whether the button is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the active modifier class is applied.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }

    /// <summary>
    /// Gets or sets the button size variant.
    /// </summary>
    [Parameter]
    public ComponentSize Size { get; set; }

    /// <summary>
    /// Gets or sets the visual style variant.
    /// </summary>
    [Parameter]
    public ButtonStyle Style { get; set; }

    /// <summary>
    /// Gets or sets the button shape variant.
    /// </summary>
    [Parameter]
    public ButtonShape Shape { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the outline style should be applied.
    /// </summary>
    [Parameter]
    public bool Outline { get; set; }

    /// <summary>
    /// The element to be used for rendering the button. Defaults to 'button'.
    /// </summary>
    [Parameter]
    public string As { get; set; } = "button";

    /// <summary>
    /// The content to be rendered inside the button.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the button is clicked.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    /// <summary>
    /// Ensures default element attributes are applied after parameters are set.
    /// </summary>
    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (this.As == "button" && !this.ComponentAttributes.ContainsKey("type"))
        {
            this.ComponentAttributes["type"] = "button";
        }
    }
    
    /// <summary>
    /// Gets the composed CSS class string for the button instance.
    /// </summary>
    protected override string CssClass => new VariantClassBuilder("fw-btn")
        .AddVariant(this.Shape, static shape => shape.ClassNames())
        .AddIf(this.Outline, "fw-btn-outline")
        .AddVariant(this.Style, static style => style.ClassNames())
        .AddVariant(this.Size, static size => size.ButtonClassNames())
        .AddIf(this.Active, "fw-btn-active")
        .Build();
}
