@namespace Firewind.Components
@inherits FirewindComponentBase

<details @attributes="ComponentAttributes">
    @ButtonTemplate(this.Label)
    <div class="@DropdownContentCssClass">
        @ChildContent
    </div>
</details>

@code
{
    /// <summary>
    /// Gets or sets the text label passed to <see cref="ButtonTemplate"/>.
    /// </summary>
    [Parameter]
    public string Label { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets the dropdown body content.
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the template used to render the dropdown trigger element.
    /// </summary>
    [Parameter] public RenderFragment<string> ButtonTemplate { get; set; } = label => __builder =>
    {
        <FWButton As="summary" class="m-1">@label</FWButton>
    };

    /// <summary>
    /// Gets or sets the theme color used for the dropdown content surface.
    /// </summary>
    [Parameter]
    public ThemeColor ContentColor { get; set; } = ThemeColor.Base300;

    /// <summary>
    /// Gets or sets a value indicating whether glow classes should be applied to dropdown content.
    /// </summary>
    [Parameter]
    public bool ContentGlow { get; set; }

    /// <summary>
    /// Gets or sets the alignment variant for dropdown content.
    /// </summary>
    [Parameter]
    public DropdownAlignment Alignment { get; set; }

    /// <summary>
    /// Gets or sets the direction variant for dropdown content.
    /// </summary>
    [Parameter]
    public DropdownDirection Direction { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the dropdown opens on hover.
    /// </summary>
    [Parameter]
    public bool OpenOnHover { get; set; }

    /// <summary>
    /// Gets the composed CSS class string for the dropdown content container.
    /// </summary>
    private string DropdownContentCssClass => new VariantClassBuilder("fw-dropdown-content z-[1] rounded-box")
        .AddVariant(this.ContentColor, static color => color.BackgroundClasses())
        .AddIf(this.ContentGlow, this.ContentColor.GlowClasses())
        .AddIf(!this.ContentGlow, "shadow")
        .Build();

    /// <summary>
    /// Gets the root CSS class for the dropdown component.
    /// </summary>
    protected override string CssClass => new VariantClassBuilder("fw-dropdown")
        .AddVariant(this.Alignment, static alignment => alignment.ClassNames())
        .AddVariant(this.Direction, static direction => direction.ClassNames())
        .AddIf(this.OpenOnHover, "fw-dropdown-hover")
        .Build();
}
