@namespace Firewind.Components
@inherits FirewindComponentBase

<div role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="@Value" style="--value:@Value;--size:@Size;--thickness:@Thickness;" @attributes="ComponentAttributes">@ResolvedDisplayText</div>

@code {
    /// <summary>
    /// Gets or sets the progress value (0-100).
    /// </summary>
    [Parameter] public int Value { get; set; }

    /// <summary>
    /// Gets or sets rendered text. Defaults to percentage.
    /// </summary>
    [Parameter] public string? DisplayText { get; set; }

    /// <summary>
    /// Gets or sets radial progress size CSS value.
    /// </summary>
    [Parameter] public string Size { get; set; } = "5rem";

    /// <summary>
    /// Gets or sets radial progress thickness CSS value.
    /// </summary>
    [Parameter] public string Thickness { get; set; } = "0.5rem";

    /// <summary>
    /// Ensures display text defaults to percentage.
    /// </summary>
    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (this.Value is < 0 or > 100)
        {
            throw new ArgumentOutOfRangeException(nameof(Value), this.Value, "Radial progress value must be between 0 and 100.");
        }
    }

    /// <summary>
    /// Gets CSS classes for radial progress component.
    /// </summary>
    protected override string CssClass => "fw-radial-progress";

    private string ResolvedDisplayText => this.DisplayText ?? $"{this.Value}%";
}
