@namespace Firewind.Components
@inherits FirewindComponentBase

@if (!string.IsNullOrWhiteSpace(Label))
{
    <label class="fw-label" for="@Id">@Label</label>
}

<textarea placeholder="@Placeholder" @onchange="HandleChangedAsync" @attributes="ComponentAttributes">@Value</textarea>

@code
{
    /// <summary>
    /// Gets or sets the textarea label.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>
    /// Gets or sets the textarea placeholder text.
    /// </summary>
    [Parameter]
    public string? Placeholder { get; set; }

    /// <summary>
    /// Gets or sets the textarea value.
    /// </summary>
    [Parameter]
    public string? Value { get; set; }

    /// <summary>
    /// Gets or sets the callback raised when <see cref="Value"/> changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the visual style variant.
    /// </summary>
    [Parameter]
    public FieldStyle Style { get; set; }

    /// <summary>
    /// Gets or sets the semantic color variant.
    /// </summary>
    [Parameter]
    public ThemeColor Color { get; set; }

    /// <summary>
    /// Gets or sets the size variant.
    /// </summary>
    [Parameter]
    public ComponentSize Size { get; set; }

    /// <summary>
    /// Gets CSS classes for the configured textarea variants.
    /// </summary>
    protected override string CssClass => new VariantClassBuilder("fw-textarea")
        .AddVariant(this.Style, static style => style.ClassNames("textarea"))
        .AddVariant(this.Color, static color => color.FormControlClassNames("textarea"))
        .AddVariant(this.Size, static size => size.FormControlClassNames("textarea"))
        .Build();

    private async Task HandleChangedAsync(ChangeEventArgs e)
    {
        this.Value = e.Value?.ToString();

        if (this.ValueChanged.HasDelegate)
        {
            await this.ValueChanged.InvokeAsync(this.Value);
        }
    }
}
