@namespace Firewind.Components
@inherits FirewindComponentBase

<input type="range" min="@Min" max="@Max" value="@Value" @attributes="ComponentAttributes" />

@code
{
    /// <summary>
    /// Gets or sets the minimum allowed value.
    /// </summary>
    [Parameter]
    public int Min { get; set; }

    /// <summary>
    /// Gets or sets the maximum allowed value.
    /// </summary>
    [Parameter]
    public int Max { get; set; } = 100;

    /// <summary>
    /// Gets or sets the current value.
    /// </summary>
    [Parameter]
    public int Value { get; set; }

    /// <summary>
    /// Gets or sets the semantic color variant.
    /// </summary>
    [Parameter]
    public ThemeColor Color { get; set; }

    /// <summary>
    /// Gets or sets the control size variant.
    /// </summary>
    [Parameter]
    public ComponentSize Size { get; set; }

    /// <summary>
    /// Gets CSS classes for the configured range variants.
    /// </summary>
    protected override string CssClass => new VariantClassBuilder("fw-range")
        .AddVariant(this.Color, static color => color.FormControlClassNames("range"))
        .AddVariant(this.Size, static size => size.FormControlClassNames("range"))
        .Build();
}
