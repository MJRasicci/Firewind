@namespace Firewind.Components
@inherits FirewindComponentBase

<input type="radio" name="@Name" @attributes="ComponentAttributes" />

@code
{
    /// <summary>
    /// Gets or sets the radio group name.
    /// </summary>
    [Parameter]
    public string Name { get; set; } = $"fw-radio-{Guid.NewGuid():N}";

    /// <summary>
    /// Gets or sets the semantic color variant.
    /// </summary>
    [Parameter]
    public ThemeColor Color { get; set; }

    /// <summary>
    /// Gets or sets the control size variant.
    /// </summary>
    [Parameter]
    public ComponentSize Size { get; set; }

    /// <summary>
    /// Gets CSS classes for the configured radio variants.
    /// </summary>
    protected override string CssClass => new VariantClassBuilder("fw-radio")
        .AddVariant(this.Color, static color => color.FormControlClassNames("radio"))
        .AddVariant(this.Size, static size => size.FormControlClassNames("radio"))
        .Build();
}
