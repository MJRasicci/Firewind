@namespace Firewind.Components
@inherits FirewindComponentBase

<input type="checkbox" @attributes="ComponentAttributes" />

@code
{
    /// <summary>
    /// Gets or sets the semantic color variant.
    /// </summary>
    [Parameter]
    public ThemeColor Color { get; set; }

    /// <summary>
    /// Gets or sets the toggle size variant.
    /// </summary>
    [Parameter]
    public ComponentSize Size { get; set; }

    /// <summary>
    /// Gets CSS classes for the configured toggle variants.
    /// </summary>
    protected override string CssClass => new VariantClassBuilder("fw-toggle")
        .AddVariant(this.Color, static color => color.FormControlClassNames("toggle"))
        .AddVariant(this.Size, static size => size.FormControlClassNames("toggle"))
        .Build();
}
