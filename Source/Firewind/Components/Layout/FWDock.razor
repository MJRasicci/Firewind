@namespace Firewind.Components
@inherits FirewindComponentBase

<div @attributes="ComponentAttributes">@ChildContent</div>

@code {
    /// <summary>
    /// Gets or sets dock item content.
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets dock size.
    /// </summary>
    [Parameter] public DockSize Size { get; set; }

    /// <summary>
    /// Gets CSS classes for dock container.
    /// </summary>
    protected override string CssClass => new VariantClassBuilder("fw-dock")
        .AddVariant(this.Size, static size => size.ClassNames())
        .Build();
}
