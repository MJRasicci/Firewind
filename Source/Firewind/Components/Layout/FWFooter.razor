@namespace Firewind.Components
@inherits FirewindComponentBase

<footer @attributes="ComponentAttributes">
    @ChildContent
</footer>

@code
{
    /// <summary>
    /// Gets or sets footer content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets footer orientation.
    /// </summary>
    [Parameter]
    public JoinOrientation Orientation { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether content should be centered.
    /// </summary>
    [Parameter]
    public bool Center { get; set; }

    /// <summary>
    /// Gets CSS classes for the footer container.
    /// </summary>
    protected override string CssClass => new VariantClassBuilder("fw-footer")
        .AddVariant(this.Orientation, static orientation => orientation.FooterClassNames())
        .AddIf(this.Center, "fw-footer-center")
        .Build();
}
