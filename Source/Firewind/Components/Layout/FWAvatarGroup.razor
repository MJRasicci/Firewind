@namespace Firewind.Components
@inherits FirewindComponentBase

<div @attributes="ComponentAttributes">
    @ChildContent
</div>

@code
{
    /// <summary>
    /// Gets or sets grouped avatar content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets CSS classes for the avatar group container.
    /// </summary>
    protected override string CssClass => "fw-avatar-group";
}
