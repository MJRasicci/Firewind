@namespace Firewind.Components
@inherits FirewindComponentBase

<img src="@Source" alt="@Alt" @attributes="ComponentAttributes" />

@code {
    /// <summary>
    /// Gets or sets image source URL.
    /// </summary>
    [Parameter] public string Source { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets image alternative text.
    /// </summary>
    [Parameter] public string Alt { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets mask shape variant.
    /// </summary>
    [Parameter] public MaskShape Shape { get; set; }

    /// <summary>
    /// Gets or sets half-mask modifier variant.
    /// </summary>
    [Parameter] public MaskHalf Half { get; set; }

    /// <summary>
    /// Gets CSS classes for mask component.
    /// </summary>
    protected override string CssClass => new VariantClassBuilder("fw-mask")
        .AddVariant(this.Shape, static shape => shape.ClassNames())
        .AddVariant(this.Half, static half => half.ClassNames())
        .Build();
}
