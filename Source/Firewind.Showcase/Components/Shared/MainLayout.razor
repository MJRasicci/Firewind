@inherits LayoutComponentBase

<!-- Header -->
<header class="bg-primary text-primary-content p-4 flex-none">
    <div class="container mx-auto flex items-center justify-between gap-4">
        <h1 class="text-2xl">Firewind Showcase</h1>
        <FWMenu TMenuItem="MenuItem" Orientation="MenuOrientation.Horizontal">
            @foreach (var item in menuItems)
            {
                <FWMenuItem Label="@item.Label" Href="@item.Href" />
            }
        </FWMenu>
        <FWThemeController Label="Theme" />
    </div>
</header>

<!-- Content -->
<main class="flex-1 min-h-0 overflow-y-auto">
    <article class="mx-auto my-4 p-4">
        @Body
    </article>
</main>

<!-- Footer -->
<footer class="bg-primary text-primary-content p-4 flex-none">
    <div class="container mx-auto">
        <p class="text-sm">Copyright &copy; 2026 Michael Rasicci</p>
    </div>
</footer>

@code {
    private readonly MenuItem[] menuItems = new[]
    {
        new MenuItem("Home", "/"),
        new MenuItem("Gallery", "/gallery"),
    };

    private record MenuItem(string Label, string Href);
}
