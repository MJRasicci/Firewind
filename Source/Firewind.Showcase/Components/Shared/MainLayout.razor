@inherits LayoutComponentBase

<!-- Header -->
<header class="bg-primary text-primary-content p-4 flex-none">
    <div class="container mx-auto flex items-center justify-between gap-4">
        <h1 class="text-2xl">Firewind Showcase</h1>
        <FWThemeController Label="Theme" />
    </div>
</header>

<!-- Content -->
<main class="flex-1 min-h-0 min-h-full overflow-y-auto">
    <div class="mx-auto min-h-full w-full">
        @Body
    </div>
</main>

<!-- Footer -->
<footer class="bg-primary text-primary-content p-4 flex-none">
    <div class="container mx-auto">
        <p class="text-sm">Copyright &copy; 2026 Michael Rasicci</p>
    </div>
</footer>
