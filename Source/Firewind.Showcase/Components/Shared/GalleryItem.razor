@inject HttpClient Http

<article class="prose prose-sm md:prose-base mx-auto w-full max-w-6xl py-2">
    <h2>@Title</h2>
    <p>@Article</p>
</article>

<div class="mx-auto my-4 flex w-full max-w-6xl flex-col gap-4 xl:grid xl:grid-cols-2">
    <div class="min-w-0 overflow-hidden">
        <FWBrowserMockup Address="@($"https://example.com/demos/{Demo.Name}")" class="h-[24rem] sm:h-[28rem] xl:h-[32rem]">
            <div class="flex min-h-full w-full flex-col items-center justify-start">
                <DynamicComponent Type="Demo" />
            </div>
        </FWBrowserMockup>
    </div>

    <div class="min-w-0 overflow-hidden">
        <FWCodeView SourceCode="@DemoSource" Language="csharp" class="h-[24rem] sm:h-[28rem] xl:h-[32rem]" />
    </div>
</div>

@code {
    [Parameter] public required string Title { get; set; }
    [Parameter] public required string Article { get; set; }
    [Parameter] public required Type Demo { get; set; }

    private string? LoadedDemoIdentity { get; set; }
    private string DemoSource { get; set; } = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        var demoIdentity = this.Demo.FullName ?? this.Demo.Name;
        if (string.Equals(this.LoadedDemoIdentity, demoIdentity, StringComparison.Ordinal))
        {
            await base.OnParametersSetAsync();
            return;
        }

        this.LoadedDemoIdentity = demoIdentity;
        this.DemoSource = await LoadDemoSourceAsync(this.Demo.Name);
        await base.OnParametersSetAsync();
    }

    /// <summary>
    /// Loads demo source text from the showcase static source manifest.
    /// </summary>
    /// <param name="demoName">The demo component type name.</param>
    /// <returns>The source file contents or a precise error message.</returns>
    private async Task<string> LoadDemoSourceAsync(string demoName)
    {
        var sourcePath = $"demos/sources/{demoName}.razor.txt";

        try
        {
            return await this.Http.GetStringAsync(sourcePath);
        }
        catch (HttpRequestException ex)
        {
            return $"Error loading source code from '{sourcePath}': {ex.Message}";
        }
    }
}
