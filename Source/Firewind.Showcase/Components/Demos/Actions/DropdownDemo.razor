<div class="flex flex-wrap gap-4 items-center justify-center px-2">
    <FWDropdown Label="Start / Bottom" Alignment="DropdownAlignment.Start" Direction="DropdownDirection.Bottom">
        <div class="p-2 w-52">
            <h2 class="font-bold">Default</h2>
            <p>Bottom-aligned dropdown content.</p>
        </div>
    </FWDropdown>

    <FWDropdown Label="End / Top" Alignment="DropdownAlignment.End" Direction="DropdownDirection.Top">
        <div class="p-2 w-52">
            <h2 class="font-bold">Top-End</h2>
            <p>Opens upward from the end edge.</p>
        </div>
    </FWDropdown>

    <FWDropdown Label="Hover / Right" Alignment="DropdownAlignment.Center" Direction="DropdownDirection.Right" OpenOnHover="true">
        <div class="p-2 w-52">
            <h2 class="font-bold">Hover</h2>
            <p>Open on hover to the right.</p>
        </div>
    </FWDropdown>
</div>
